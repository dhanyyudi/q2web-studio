{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest", "--browser=chromium"],
      "lifecycle": "lazy"
    },
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"],
      "lifecycle": "lazy"
    },
    "context7": {
      "url": "https://mcp.context7.com/mcp",
      "lifecycle": "lazy"
    },
    "pinchtab": {
      "command": "pinchtab",
      "args": ["mcp"],
      "lifecycle": "lazy"
    }
  }
}
